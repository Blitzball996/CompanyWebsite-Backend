# Copy this to ".env" in the backend repo root and fill it in (the deploy script
# generates one automatically with random secrets if it's missing).
SITE_DOMAIN=blitzball.lol
DASHBOARD_USER=admin
DASHBOARD_PASS=change-me-to-a-strong-password
VISITOR_SALT=change-me-to-a-random-string
DB_PASSWORD=change-me-to-a-random-db-password
# true = store raw visitor IPs (personal data; ensure privacy-policy compliance)
STORE_IP=true
