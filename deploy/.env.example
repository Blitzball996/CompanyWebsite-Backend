# Copy this to ".env" in the backend repo root and fill it in (the deploy script
# generates one automatically with random secrets if it's missing).
SITE_DOMAIN=blitzball.lol
DASHBOARD_USER=admin
DASHBOARD_PASS=change-me-to-a-strong-password
VISITOR_SALT=change-me-to-a-random-string
DB_PASSWORD=change-me-to-a-random-db-password
# true = store raw visitor IPs (personal data; ensure privacy-policy compliance)
STORE_IP=true

# ---- Payments: auto-issue license on successful payment (optional) ----
# Webhook signing secret — set the SAME value in Airwallex webhook config.
# Leave empty to disable signature checking (NOT recommended in production).
WEBHOOK_SECRET=

# ---- Email: deliver the license key to the buyer (optional) ----
# If unset, keys are still issued (visible in dashboard) but not emailed.
# Example for a typical provider:  SMTP_HOST=smtp.exmail.qq.com  SMTP_PORT=465
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Blitzball Labs <noreply@blitzball.lol>

# Ed25519 license signing key (base64url, 32-byte seed).
# MUST match the public key embedded in the desktop apps (CloseCrab / Blitz DAW),
# otherwise every activation fails token verification. Generate ONCE and keep it
# secret; if unset, the server auto-generates a key into the license_data volume
# (which will NOT match already-shipped apps). Do NOT commit the real value.
LICENSE_PRIVATE_KEY=replace-with-your-32-byte-seed-base64url

# ---- Customer accounts (register/login + receipts) ----
# Base URL used in verification/password-reset email links. Defaults to https://SITE_DOMAIN.
APP_BASE_URL=https://blitzball.lol
# true in production (HTTPS) so the session cookie gets the Secure flag.
COOKIE_SECURE=true

# ---- 极验验证码 GeeTest (anti-bot on register/login; optional) ----
# Register at geetest.com to get these. Unset = captcha not enforced.
GEETEST_ID=
GEETEST_KEY=
