# Caddy reverse proxy for Blitzball Labs (auto HTTPS via Let's Encrypt).
# SITE_DOMAIN is injected from the environment (see docker-compose.prod.yml / .env).
{$SITE_DOMAIN} {
	encode zstd gzip

	# API + dashboard + analytics script + health → Go backend (internal only)
	@backend path /api/* /analytics.js /dashboard /health
	handle @backend {
		reverse_proxy server:8090
	}

	# Everything else → static frontend files (the CompanyWebsite repo, mounted at /srv)
	handle {
		root * /srv
		try_files {path} {path}/ /index.html
		file_server
	}
}
