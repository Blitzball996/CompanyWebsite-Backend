# Server
PORT=8090
# Comma-separated allowed origins for the collect endpoint (your website URLs)
ALLOWED_ORIGINS=http://localhost:8080,https://blitzball996.github.io

# PostgreSQL
DATABASE_URL=postgres://analytics:analytics@localhost:5432/analytics?sslmode=disable

# Dashboard login (change these!)
DASHBOARD_USER=admin
DASHBOARD_PASS=change-me-please

# Salt for hashing visitor IP+UA into an anonymous id (change to a random string)
VISITOR_SALT=please-change-this-random-salt
